<tool id="gxit_query_builder" tool_type="interactive" name="Rejuve Annotaiton Query builder" version="0.3.0+galaxy0">
    <icon src="rejuve.bio.png"/>
    <description>Rejuve Annotaiton Query builder</description>
    <requirements>
        <container type="docker">tibex/gxit-query-builder:20250624-184132</container>
    </requirements>
    <entry_points>
        <entry_point name="Rejuve Annotaiton Query builder"  label="Rejuve Annotaiton Query builder" requires_domain="False" requires_path_in_url="True">
            <port>4173</port>
            <url>/</url>
        </entry_point>
    </entry_points>
    <command><![CDATA[
    node /usr/src/app/server.js --output '$result' --output2 '$result2'
    ]]>
    </command>

    <inputs>
    </inputs>

    <outputs>
        <data name="result" format="tabular"/>
        <data name="result2" format="tabular"/>
    </outputs>

    <tests></tests>
